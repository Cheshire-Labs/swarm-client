{
  "client_id": "lab-workstation-1",
  "site": "boston",
  "lab": "molbio",
  "workcell": null,
  "platform": {
    "url": "wss://swarm.cheshirelabs.io/ws",
    "api_key": "${SWARM_API_KEY}",
    "heartbeat_interval": 30.0,
    "command_timeout": 60.0,
    "reconnect_backoff": [1, 2, 4, 8, 16, 30]
  },
  "devices": [
    {
      "device_id": "shaker_1",
      "type": "shaker",
      "name": "Inheco Thermoshake",
      "driver": {
        "type": "plr",
        "backend": "InhecoThermoShake",
        "connection": {
          "type": "serial",
          "port": "COM3",
          "baudrate": 9600
        }
      }
    },
    {
      "device_id": "centrifuge_1",
      "type": "centrifuge",
      "name": "Agilent VS6000",
      "driver": {
        "type": "sim"
      }
    },
    {
      "device_id": "arm_1",
      "type": "transporter",
      "name": "PreciseFlex 400",
      "driver": {
        "type": "plr",
        "backend": "PreciseFlex400Backend",
        "teachpoints_file": "teachpoints.xml",
        "connection": {
          "type": "tcp",
          "host": "192.168.1.100",
          "tcp_port": 5000
        }
      }
    }
  ]
}
